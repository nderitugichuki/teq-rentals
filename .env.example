# Development defaults. Override every production value before deployment.
DJANGO_SECRET_KEY=dev-only-change-me-use-a-long-random-secret-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173

POSTGRES_DB=rental_management
POSTGRES_USER=rental_user
POSTGRES_PASSWORD=rental_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONNECT_TIMEOUT=5

ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7
ANON_THROTTLE_RATE=60/minute
USER_THROTTLE_RATE=1000/hour

VITE_API_BASE_URL=http://localhost:8000/api/v1
BACKEND_PORT=8000
FRONTEND_PORT=80

# Playwright E2E testing
E2E_API_BASE_URL=http://backend:8000/api/v1
E2E_FRONTEND_API_BASE_URL=http://backend:8000/api/v1
E2E_LANDLORD_EMAIL=e2e.landlord@example.com
E2E_LANDLORD_PASSWORD=StrongPass123!
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Production examples
# DJANGO_DEBUG=False
# DJANGO_SECRET_KEY=replace-with-a-50-plus-character-random-secret-key
# DJANGO_ALLOWED_HOSTS=your-api-domain.com
# DJANGO_CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com
# VITE_API_BASE_URL=https://your-api-domain.com/api/v1
# POSTGRES_DB=your_production_database
# POSTGRES_USER=your_production_database_user
# POSTGRES_PASSWORD=replace-with-a-strong-database-password
